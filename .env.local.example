OPENAI_API_KEY=sk-...

# 모델 티어
# - OPENAI_MODEL: 기본(고품질) 티어 — 분석(analyze)·이력서 생성(generate)에 사용
# - OPENAI_MODEL_ECONOMY: 절약 티어 — 면접질문(interview)에 사용
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_ECONOMY=gpt-4o-mini
# 이미지(공고·이력서 스크린샷) OCR용 비전 모델
OPENAI_MODEL_VISION=gpt-4o-mini

# 작업별 개별 지정(선택) — 설정 시 위 티어보다 우선
# OPENAI_MODEL_ANALYZE=gpt-4o
# OPENAI_MODEL_GENERATE=gpt-4o
# OPENAI_MODEL_INTERVIEW=gpt-4o-mini

# 기타
OPENAI_MAX_TOKENS=16000
DAILY_LIMIT=30
APP_PASSWORD=
